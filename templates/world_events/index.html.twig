{% extends 'base.html.twig' %}

{% block title %}Événements Mondiaux{% endblock %}

{% block body %}
<div class="content-container">
    <h1>Chronologie des Événements</h1>
    
    {% if events is empty %}
        <p class="no-content">Aucun événement enregistré.</p>
    {% else %}
        {# Timeline Box #}
        <div class="timeline-box">
            <div class="timeline-controls">
                <button class="zoom-btn" data-action="zoom-out">−</button>
                <span class="zoom-level">100%</span>
                <button class="zoom-btn" data-action="zoom-in">+</button>
                <button class="zoom-btn" data-action="zoom-reset">Réinitialiser</button>
            </div>
            
            <div class="timeline-viewport">
                <div class="timeline-track" id="timeline-track">
                    {% for event in events %}
                        {# Validation: Check for missing required dates (except last event for end date) #}
                        {% if event.startYear is null or event.startMonth is null or event.startDay is null %}
                            <div class="timeline-error">
                                ⚠️ Événement "{{ event.title }}" : Date de début manquante
                            </div>
                        {% elseif not loop.last and not event.isOngoing and (event.endYear is null or event.endMonth is null or event.endDay is null) %}
                            <div class="timeline-error">
                                ⚠️ Événement "{{ event.title }}" : Date de fin manquante
                            </div>
                        {% else %}
                            <div class="timeline-segment" 
                                 data-event-id="{{ event.id }}"
                                 data-start="{{ event.startYear }}-{{ event.startMonth }}-{{ event.startDay }}"
                                 data-end="{% if event.isOngoing %}ongoing{% else %}{{ event.endYear }}-{{ event.endMonth }}-{{ event.endDay }}{% endif %}"
                                 style="background-color: {{ event.color }};"
                                 title="{{ event.title }}">
                                <span class="segment-label">{{ event.title }}</span>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Events List #}
        <div class="events-list" style="margin-top: 40px;">
            <h2>Liste des Événements</h2>
            {% for event in events %}
                <div class="event-item">
                    <h3 class="event-title" style="color: {{ event.color }};">{{ event.title }}</h3>
                    <div class="event-date">
                        <strong>Début :</strong> {{ event.startDay }}/{{ event.startMonth }}/{{ event.startYear }}
                        {% if event.isOngoing %}
                            | <span class="badge-ongoing">En cours</span>
                        {% else %}
                            | <strong>Fin :</strong> {{ event.endDay }}/{{ event.endMonth }}/{{ event.endYear }}
                        {% endif %}
                    </div>
                    {% if event.description %}
                        <div class="event-description">{{ event.description|nl2br }}</div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<script src="{{ asset('js/timeline-zoom.js') }}"></script>
{% endblock %}
