{% extends 'base.html.twig' %}

{% block title %}The Rift Chronicles - The Forgotten Worlds{% endblock %}

{% block leftContent %}
    <div class="homepage-welcome">
        <h2 class="welcome-title">🏰 Bienvenue dans les Chronicles</h2>
        <p class="welcome-description">
            Plongez dans l'univers des <strong>Chronicles</strong>, un système de gestion d'univers fictif 
            qui vous permet de créer et organiser vos espèces, races et personnages fantastiques.
        </p>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number">{{ stats.species_count ?? 0 }}</div>
                <div class="stat-label">Espèces</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">{{ stats.races_count ?? 0 }}</div>
                <div class="stat-label">Races</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">{{ stats.characters_count ?? 0 }}</div>
                <div class="stat-label">Personnages</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">{{ stats.average_age ?? 0 }}</div>
                <div class="stat-label">Âge Moyen</div>
            </div>
        </div>

        {% if recent_characters and recent_characters|length > 0 %}
        <div class="recent-section">
            <h3 class="recent-title">📖 Personnages Récents</h3>
            <div class="recent-characters">
                {% for character in recent_characters %}
                <div class="recent-character">
                    <div class="character-info">
                        <strong>{{ character.name }}</strong>
                        <span class="character-species">{{ character.species.name }}</span>
                        {% if character.race %}
                            <span class="character-race">• {{ character.race.name }}</span>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <div class="features-section">
            <h3 class="features-title">✨ Fonctionnalités</h3>
            <ul class="features-list">
                <li><span class="feature-icon">🧬</span> <strong>Espèces</strong> : Consultez les différentes espèces avec leurs descriptions</li>
                <li><span class="feature-icon">👥</span> <strong>Races</strong> : Découvrez les races associées à chaque espèce</li>
                <li><span class="feature-icon">🎭</span> <strong>Personnages</strong> : Explorez les personnages de cet univers</li>
                <li><span class="feature-icon">🌌</span> <strong>Dimensions</strong> : Naviguez dans les différents plans d'existence</li>
            </ul>
        </div>

        {% if not app.user %}
        <div class="auth-prompt">
            <p class="auth-text">
                <span class="auth-icon">🔐</span>
                <a href="{{ path('login') }}" class="auth-link">Connectez-vous</a> pour accéder à toutes les fonctionnalités
                ou <a href="{{ path('register') }}" class="auth-link">créez un compte</a> pour rejoindre l'aventure !
            </p>
        </div>
        {% elseif not app.user.hasAnyRoles %}
        <div class="role-info">
            <p class="role-text">
                <span class="info-icon">ℹ️</span>
                Votre compte est en attente d'activation. Contactez un administrateur pour obtenir des permissions.
            </p>
        </div>
        {% endif %}
    </div>
{% endblock %}

{% block body %}
    <div class="homepage-main">
        <div class="navigation-grid">
            <div class="nav-section">
                <h2 class="nav-section-title">🗺️ Explorer l'Univers</h2>
                <div class="nav-cards">
                    <a href="{{ path('beings_index') }}" class="nav-card beings-card">
                        <div class="nav-card-icon">🧬</div>
                        <div class="nav-card-content">
                            <h3>Êtres Vivants</h3>
                            <p>Découvrez les espèces et races qui peuplent cet univers</p>
                            <div class="nav-card-stats">
                                {{ stats.species_count ?? 0 }} espèces • {{ stats.races_count ?? 0 }} races
                            </div>
                        </div>
                    </a>

                    <a href="{{ path('characters_index') }}" class="nav-card characters-card">
                        <div class="nav-card-icon">🎭</div>
                        <div class="nav-card-content">
                            <h3>Personnages</h3>
                            <p>Explorez les héros, vilains et personnages de cette saga</p>
                            <div class="nav-card-stats">
                                {{ stats.characters_count ?? 0 }} personnages créés
                            </div>
                        </div>
                    </a>

                    <div class="nav-card disabled-card">
                        <div class="nav-card-icon">🌌</div>
                        <div class="nav-card-content">
                            <h3>Dimensions</h3>
                            <p>Naviguez dans les différents plans d'existence</p>
                            <div class="nav-card-status">Bientôt disponible</div>
                        </div>
                    </div>

                    <div class="nav-card disabled-card">
                        <div class="nav-card-icon">💡</div>
                        <div class="nav-card-content">
                            <h3>Idées & Concepts</h3>
                            <p>Explorez les idées et concepts en développement</p>
                            <div class="nav-card-status">En préparation</div>
                        </div>
                    </div>
                </div>
            </div>

            {% if app.user %}
            <div class="nav-section">
                <h2 class="nav-section-title">👤 Mon Espace</h2>
                <div class="nav-cards">
                    <a href="{{ path('profile') }}" class="nav-card profile-card">
                        <div class="nav-card-icon">👤</div>
                        <div class="nav-card-content">
                            <h3>Mon Profil</h3>
                            <p>Gérez vos informations personnelles et préférences</p>
                            <div class="nav-card-stats">
                                Connecté en tant que <strong>{{ app.user.username }}</strong>
                            </div>
                        </div>
                    </a>

                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_dashboard') }}" class="nav-card admin-card">
                        <div class="nav-card-icon">⚙️</div>
                        <div class="nav-card-content">
                            <h3>Administration</h3>
                            <p>Gérez les utilisateurs, espèces et contenu du site</p>
                            <div class="nav-card-stats">
                                Accès administrateur
                            </div>
                        </div>
                    </a>
                    {% endif %}
                </div>
            </div>
            {% endif %}
        </div>
    </div>
{% endblock %}