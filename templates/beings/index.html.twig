{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} - {{ parent() }}{% endblock %}

{% block page_title %}{{ page_title }}{% endblock %}

{% block body %}
<div class="page-container">
    <!-- Beings Header -->
    <div class="beings-header">
        <h1>Espèces et Créatures</h1>
        <p>Explorez les diverses espèces et races qui habitent les Mondes Oubliés</p>

        <!-- Search and Filter Controls -->
        <div class="beings-controls">
            <div class="search-section">
                <form method="GET" action="{{ path('beings_index') }}" class="search-form">
                    <div class="search-group">
                        <input type="text" name="search" value="{{ search }}" 
                               placeholder="Rechercher des espèces, races ou contenus..." class="search-input">
                        <select name="specie" class="filter-select">
                            <option value="">Toutes les Espèces</option>
                            {% for speciesName in allSpecies %}
                                <option value="{{ speciesName }}" {{ filterSpecie == speciesName ? 'selected' : '' }}>
                                    {{ speciesName }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="search-actions">
                        <button type="submit" class="search-btn">Rechercher</button>
                        <a href="{{ path('beings_index') }}" class="clear-btn">Effacer</a>
                    </div>
                </form>
            </div>
        </div>
        
        {% if is_granted('ROLE_ADMIN') %}
        <div class="admin-tools">
            <button class="admin-btn" onclick="openAdminModal()">
                <span>⚙️</span> Gérer les Espèces
            </button>
        </div>
        {% endif %}
    </div>

    <!-- Results Summary -->
    {% if search is not empty or filterSpecie is not empty %}
    <div class="results-summary">
        <p>
            {% if search is not empty %}
                Résultats pour "<strong>{{ search }}</strong>"
            {% endif %}
            {% if filterSpecie is not empty %}
                {% if search is not empty %} dans {% else %}Affichage {% endif %}
                l'espèce : <strong>{{ filterSpecie }}</strong>
            {% endif %}
            - {{ totalSpecies }} espèce(s) trouvée(s)
        </p>
    </div>
    {% endif %}

    <!-- Species Grid -->
    <div class="beings-grid">
        {% for species in species %}
            <div class="species-card" data-species="{{ species.name }}" data-species-id="{{ species.id }}">
                <!-- Species Header -->
                <div class="species-header" onclick="window.location.href='{{ path('beings_species', {'speciesId': species.id}) }}'">
                    <div class="species-image">
                        {% if species.icon %}
                            <img src="{{ asset('images/species/' ~ species.icon) }}" 
                                 alt="{{ species.name }}"
                                 onerror="this.src='{{ asset('images/icons/icon_default.png') }}'">
                        {% else %}
                            <img src="{{ asset('images/icons/icon_default.png') }}" alt="{{ species.name }}">
                        {% endif %}
                    </div>
                    <div class="species-info">
                        <h2 class="species-name">{{ species.name }}</h2>
                    </div>
                </div>

                <!-- Species Description -->
                {% if species.description %}
                <div class="species-description-box">
                    <p class="species-description">
                        {{ species.description|length > 200 ? (species.description|slice(0, 200) ~ '...') : species.description }}
                    </p>
                </div>
                {% endif %}

                <!-- Species Actions -->
                <div class="species-actions">
                    {% if species.races is not empty %}
                    <button class="btn-show-races" onclick="event.stopPropagation(); window.location.href='{{ path('beings_species', {'speciesId': species.id}) }}'">
                        Races
                    </button>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="no-results">
                <p>Aucune espèce trouvée.</p>
                {% if is_granted('ROLE_ADMIN') %}
                <button class="btn-primary" onclick="addNewSpecies()">
                    Ajouter une Nouvelle Espèce
                </button>
                {% endif %}
            </div>
        {% endfor %}
    </div>

    <!-- Pagination -->
    {% if totalPages > 1 %}
    <div class="pagination">
        {% if currentPage > 1 %}
            <a href="{{ path('beings_index', {'page': currentPage - 1, 'search': search, 'specie': filterSpecie}) }}" class="pagination-btn">
                « Précédent
            </a>
        {% endif %}
        
        {% for page in 1..totalPages %}
            {% if page == currentPage %}
                <span class="pagination-current">{{ page }}</span>
            {% elseif page <= 3 or page >= totalPages - 2 or (page >= currentPage - 1 and page <= currentPage + 1) %}
                <a href="{{ path('beings_index', {'page': page, 'search': search, 'specie': filterSpecie}) }}" class="pagination-btn">
                    {{ page }}
                </a>
            {% elseif page == 4 and currentPage > 6 %}
                <span class="pagination-ellipsis">...</span>
            {% elseif page == totalPages - 3 and currentPage < totalPages - 5 %}
                <span class="pagination-ellipsis">...</span>
            {% endif %}
        {% endfor %}
        
        {% if currentPage < totalPages %}
            <a href="{{ path('beings_index', {'page': currentPage + 1, 'search': search, 'specie': filterSpecie}) }}" class="pagination-btn">
                Suivant »
            </a>
        {% endif %}
    </div>
    {% endif %}
</div>

<!-- Admin Management Modal -->
{% if is_granted('ROLE_ADMIN') %}
<div id="adminModal" class="modal" style="display: none;" onclick="closeAdminModal()">
    <div class="modal-content modal-large" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>⚙️ Gestion des Espèces & Races</h2>
            <button class="modal-close" onclick="closeAdminModal()">×</button>
        </div>
        
        <div class="modal-body">
            <!-- Quick Actions -->
            <div class="admin-quick-actions">
                <button class="btn btn-primary" onclick="window.location.href='{{ path('admin_species_new') }}'">
                    ➕ Créer une Espèce
                </button>
                <button class="btn btn-primary" onclick="window.location.href='{{ path('admin_race_new') }}'">
                    ➕ Créer une Race
                </button>
            </div>

            <!-- Species List -->
            <div class="admin-section">
                <h3>Espèces Existantes</h3>
                <div class="admin-entities-list">
                    {% for speciesItem in species %}
                        <div class="admin-entity-item">
                            <div class="admin-entity-info">
                                {% if speciesItem.icon %}
                                    <img src="{{ asset('images/species/' ~ speciesItem.icon) }}" 
                                         alt="{{ speciesItem.name }}"
                                         class="admin-entity-icon"
                                         onerror="this.style.display='none'">
                                {% else %}
                                    <span class="admin-entity-icon-placeholder">🧬</span>
                                {% endif %}
                                <div>
                                    <strong>{{ speciesItem.name }}</strong>
                                    <span class="admin-entity-meta">{{ speciesItem.races|length }} race(s)</span>
                                </div>
                            </div>
                            <div class="admin-entity-actions">
                                <button class="btn btn-sm btn-outline" onclick="window.location.href='{{ path('admin_species_edit', {'id': speciesItem.id}) }}'">
                                    ✏️ Éditer
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="confirmDeleteSpecies({{ speciesItem.id }}, '{{ speciesItem.name }}')">
                                    🗑️
                                </button>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- View Full Admin -->
            <div class="admin-section">
                <button class="btn btn-secondary btn-block" onclick="window.location.href='{{ path('admin_species_management') }}'">
                    📊 Accéder à la Gestion Complète
                </button>
            </div>
        </div>
    </div>
</div>
{% endif %}

<script>
{% if is_granted('ROLE_ADMIN') %}
// Admin functions
function openAdminModal() {
    document.getElementById('adminModal').style.display = 'block';
}

function closeAdminModal() {
    document.getElementById('adminModal').style.display = 'none';
}

function editSpecies(speciesId) {
    // Redirect to species edit page
    window.location.href = '/admin/species-management/species/' + speciesId + '/edit';
}

function confirmDeleteSpecies(speciesId, speciesName) {
    if (confirm(`Êtes-vous sûr de vouloir supprimer l'espèce "${speciesName}" ? Cela supprimera également toutes les races et personnages associés.`)) {
        // Create a form and submit it for POST request
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/species-management/species/' + speciesId + '/delete';
        document.body.appendChild(form);
        form.submit();
    }
}

function addRaceToSpecies(speciesId) {
    // Redirect to new race page with species pre-selected
    window.location.href = '/admin/species-management/race/new?species=' + speciesId;
}

function confirmDeleteRace(raceId, raceName) {
    if (confirm(`Êtes-vous sûr de vouloir supprimer la race "${raceName}" ? Cela supprimera également tous les personnages associés.`)) {
        // Create a form and submit it for POST request
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/species-management/race/' + raceId + '/delete';
        document.body.appendChild(form);
        form.submit();
    }
}

function addNewSpecies() {
    // Redirect to new species page
    window.location.href = '{{ path('admin_species_new') }}';
}
{% endif %}
</script>
{% endblock %}