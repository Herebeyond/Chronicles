{% extends 'base.html.twig' %}

{% block title %}Changer mon mot de passe{% endblock %}

{% block page_title %}Changer mon mot de passe{% endblock %}

{% block body %}
<div class="password-change-container">
    
    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-error">
            {{ message }}
        </div>
    {% endfor %}

    <div class="alert-warning">
        <strong>Sécurité :</strong> Pour votre sécurité, vous devez saisir votre mot de passe actuel avant de pouvoir le changer.
    </div>

    {{ form_start(changePasswordForm) }}
        
        <div class="form-group">
            {{ form_label(changePasswordForm.currentPassword, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(changePasswordForm.currentPassword, {'attr': {
                'class': 'form-input'
            }}) }}
            {{ form_errors(changePasswordForm.currentPassword) }}
        </div>

        <div class="password-section">
            <h4>Nouveau mot de passe</h4>
            
            <div class="form-group">
                {{ form_label(changePasswordForm.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(changePasswordForm.plainPassword.first, {'attr': {
                    'class': 'form-input'
                }}) }}
                {{ form_errors(changePasswordForm.plainPassword.first) }}
            </div>

            <div class="form-group">
                {{ form_label(changePasswordForm.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(changePasswordForm.plainPassword.second, {'attr': {
                    'class': 'form-input'
                }}) }}
                {{ form_errors(changePasswordForm.plainPassword.second) }}
            </div>
        </div>

        <div class="password-requirements">
            <strong>Conseils pour un mot de passe sécurisé :</strong>
            <ul>
                <li>Au moins 8 caractères</li>
                <li>Mélange de lettres majuscules et minuscules</li>
                <li>Inclut des chiffres et des caractères spéciaux</li>
                <li>Évitez les mots du dictionnaire</li>
            </ul>
        </div>

        <div class="form-buttons">
            <button type="submit" class="form-button primary-green">
                Changer le mot de passe
            </button>
            <a href="{{ path('profile') }}" class="form-button cancel">
                Annuler
            </a>
        </div>

    {{ form_end(changePasswordForm) }}
</div>

{% endblock %}