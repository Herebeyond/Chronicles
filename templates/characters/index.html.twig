{% extends 'base.html.twig' %}

{% block title %}Personnages - The Rift Chronicles{% endblock %}

{% block body %}
    <button id="Return" onclick="window.history.back()">Retour</button>

    <div class="beings-header beings-header--compact">
        <h1>Personnages</h1>
        <p>Explorez les personnages, regroupés par espèce et par race.</p>
    </div>

    {% if is_granted('ROLE_ADMIN') %}
    <div class="margin-bottom-20">
        <a href="{{ path('admin_characters') }}" class="btn-admin">Gérer les Personnages</a>
    </div>
    {% endif %}

    <!-- Search and Filters -->
    <div class="search-filter-form">
        <form method="GET">
            <div class="form-group">
                <label>Rechercher un personnage</label>
                <input type="text" name="search" value="{{ search }}" placeholder="Nom du personnage...">
            </div>
            <div class="form-group characters-filter-species">
                <label>Filtrer par espèce</label>
                <select name="species">
                    <option value="">Toutes les espèces</option>
                    {% for specie in species %}
                        <option value="{{ specie.id }}" {% if species_filter == specie.id %}selected{% endif %}>{{ specie.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <button type="submit">Rechercher</button>
                {% if search or species_filter %}
                    <a href="{{ path('characters_index') }}" class="btn-reset">Réinitialiser</a>
                {% endif %}
            </div>
        </form>
    </div>

    {% if characters is empty %}
        <div class="no-content-message">
            <h3>Aucun personnage trouvé</h3>
            {% if search %}
                <p>Aucun personnage ne correspond à votre recherche "{{ search }}".</p>
            {% elseif species_filter %}
                <p>Aucun personnage trouvé pour l'espèce sélectionnée.</p>
            {% else %}
                <p>Il n'y a actuellement aucun personnage dans la base de données.</p>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <p><a href="{{ path('admin_characters') }}" class="btn">Créer le premier personnage</a></p>
            {% endif %}
        </div>
    {% else %}
        <div class="characters-taxonomy-grid">
        {% for specie in species %}
            {% set species_characters = [] %}
            {% for character in characters %}
                {% if character.species and character.species.id == specie.id %}
                    {% set species_characters = species_characters|merge([character]) %}
                {% endif %}
            {% endfor %}

            {% if species_characters|length > 0 %}
                <section class="taxonomy-species-card" id="specie-{{ specie.id }}">
                    <header class="taxonomy-species-header">
                        <h2 class="taxonomy-species-name">{{ specie.name }}</h2>
                        <span class="taxonomy-species-count">{{ species_characters|length }} personnage{{ species_characters|length > 1 ? 's' : '' }}</span>
                    </header>

                    <div class="taxonomy-races-list">
                        {% set races_with_characters = {} %}
                        {% for character in species_characters %}
                            {% set race_id = character.race ? ('race_' ~ character.race.id) : 'no_race' %}
                            {% set race_id_display = character.race ? character.race.id : 'no_race' %}
                            {% set race_name = character.race ? character.race.name : 'Sans race' %}
                            {% if not races_with_characters[race_id] is defined %}
                                {% set races_with_characters = races_with_characters|merge({(race_id): {'name': race_name, 'id_display': race_id_display, 'characters': []}}) %}
                            {% endif %}
                            {% set temp_chars = races_with_characters[race_id]['characters']|merge([character]) %}
                            {% set races_with_characters = races_with_characters|merge({(race_id): {'name': race_name, 'id_display': race_id_display, 'characters': temp_chars}}) %}
                        {% endfor %}

                        {% for race_id, race_data in races_with_characters %}
                            <details class="taxonomy-race-item" data-race-id="{{ race_data.id_display }}">
                                <summary class="taxonomy-race-summary" id="race-{{ race_data.id_display }}">
                                    <span class="taxonomy-race-name">{{ race_data.name }}</span>
                                    <span class="taxonomy-race-count">{{ race_data.characters|length }} personnage{{ race_data.characters|length > 1 ? 's' : '' }}</span>
                                </summary>

                                <ul class="taxonomy-characters-list" id="characters-{{ race_data.id_display }}">
                                    {% for character in race_data.characters %}
                                        <li class="taxonomy-character-item" onclick="window.location.href='{{ path('characters_show', {characterId: character.id}) }}'">
                                            <span>{{ character.name }}</span>
                                            {% if character.occupation %}
                                                <small class="taxonomy-character-meta">{{ character.occupation }}</small>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                </ul>
                            </details>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        {% endfor %}
        </div>
    {% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Auto-submit form when species filter changes
const speciesFilterSelect = document.querySelector('select[name="species"]');
if (speciesFilterSelect) {
    speciesFilterSelect.addEventListener('change', function() {
        this.form.submit();
    });
}
</script>
{% endblock %}
