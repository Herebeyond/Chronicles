{% extends 'base.html.twig' %}

{% block title %}Gestion du Calendrier{% endblock %}

{% block body %}
<div class="admin-container">
    <h1>Gestion du Calendrier</h1>
    
    <div class="admin-actions">
        <a href="{{ path('world_events_index') }}" class="btn-secondary">Voir la chronologie</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="calendar-summary-card">
        <h3>Résumé</h3>
        <p><strong>Nombre de mois :</strong> {{ months|length }}</p>
        <p><strong>Total de jours dans l'année :</strong> {{ totalDays }}</p>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>N°</th>
                <th>Nom du mois</th>
                <th>Nombre de jours</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for month in months %}
                <tr>
                    <td>{{ month.monthNumber }}</td>
                    <td><strong>{{ month.name }}</strong></td>
                    <td>{{ month.daysCount }}</td>
                    <td>{{ month.description ?? '-' }}</td>
                    <td class="actions-cell">
                        <a href="{{ path('admin_calendar_edit', {id: month.id}) }}" class="btn-edit">Modifier</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
