{% extends 'base.html.twig' %}

{% block title %}{% if isEdit %}Modifier{% else %}Créer{% endif %} un événement{% endblock %}

{% block body %}
<div class="admin-container">
    <h1>{% if isEdit %}Modifier{% else %}Créer{% endif %} un Événement</h1>
    
    <form method="post" class="form-container">
        <div class="form-group">
            <label for="title" class="form-label">Titre *</label>
            <input type="text" id="title" name="title" class="form-input" required value="{{ event.title ?? '' }}">
        </div>

        <div class="form-group">
            <label for="description" class="form-label">Description</label>
            <textarea id="description" name="description" class="form-input" rows="4">{{ event.description ?? '' }}</textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="start_year" class="form-label">Année de début *</label>
                <input type="number" id="start_year" name="start_year" class="form-input" required value="{{ event.startYear ?? '' }}">
            </div>
            <div class="form-group">
                <label for="start_month" class="form-label">Mois de début *</label>
                <input type="number" id="start_month" name="start_month" class="form-input" required min="1" max="12" value="{{ event.startMonth ?? '' }}">
            </div>
            <div class="form-group">
                <label for="start_day" class="form-label">Jour de début *</label>
                <input type="number" id="start_day" name="start_day" class="form-input" required min="1" max="30" value="{{ event.startDay ?? '' }}">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="end_year" class="form-label">Année de fin (vide si en cours)</label>
                <input type="number" id="end_year" name="end_year" class="form-input" value="{{ event.endYear ?? '' }}">
            </div>
            <div class="form-group">
                <label for="end_month" class="form-label">Mois de fin</label>
                <input type="number" id="end_month" name="end_month" class="form-input" min="1" max="12" value="{{ event.endMonth ?? '' }}">
            </div>
            <div class="form-group">
                <label for="end_day" class="form-label">Jour de fin</label>
                <input type="number" id="end_day" name="end_day" class="form-input" min="1" max="30" value="{{ event.endDay ?? '' }}">
            </div>
        </div>

        <div class="form-group">
            <label for="color" class="form-label">Couleur</label>
            <input type="color" id="color" name="color" class="form-input" value="{{ event.color ?? '#3498db' }}">
        </div>

        <div class="form-group">
            <label for="significance" class="form-label">Importance/Signification</label>
            <textarea id="significance" name="significance" class="form-input" rows="3">{{ event.significance ?? '' }}</textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="form-button">{% if isEdit %}Modifier{% else %}Créer{% endif %}</button>
            <a href="{{ path('admin_world_events_index') }}" class="btn-secondary">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}
