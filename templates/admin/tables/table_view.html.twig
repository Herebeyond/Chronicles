{% extends 'base.html.twig' %}

{% block title %}{{ config.title }} - Administration{% endblock %}

{% block body %}
<div class="container">
    <div class="admin-header">
        <div>
            <h1>{{ config.icon }} {{ config.title }}</h1>
            <p>{{ config.description }}</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">
                ← Back to Dashboard
            </a>
            {% if table == 'species' %}
                <a href="{{ path('admin_species_management') }}" class="btn btn-primary">
                    🧬 Manage Species
                </a>
            {% elseif table == 'users' %}
                <a href="{{ path('admin_users_index') }}" class="btn btn-primary">
                    👥 Manage Users
                </a>
            {% endif %}
        </div>
    </div>

    <!-- Table Navigation -->
    <div class="table-navigation">
        <a href="{{ path('admin_table_view', {'table': 'species'}) }}" 
           class="nav-tab {{ table == 'species' ? 'active' : '' }}">
            🧬 Species ({{ all_counts.species }})
        </a>
        <a href="{{ path('admin_table_view', {'table': 'races'}) }}" 
           class="nav-tab {{ table == 'races' ? 'active' : '' }}">
            🎭 Races ({{ all_counts.races }})
        </a>
        <a href="{{ path('admin_table_view', {'table': 'characters'}) }}" 
           class="nav-tab {{ table == 'characters' ? 'active' : '' }}">
            ⚔️ Characters ({{ all_counts.characters }})
        </a>
        <a href="{{ path('admin_table_view', {'table': 'users'}) }}" 
           class="nav-tab {{ table == 'users' ? 'active' : '' }}">
            👥 Users ({{ all_counts.users }})
        </a>
    </div>

    <!-- Filters -->
    {% if table in ['races', 'characters'] %}
    <div class="table-filters">
        <form method="GET" class="filter-form">
            {% if table == 'races' and filters.species %}
                <div class="filter-item">
                    <label>Filtered by Species ID:</label>
                    <span class="filter-value">{{ filters.species }}</span>
                    <a href="{{ path('admin_table_view', {'table': 'races'}) }}" class="clear-filter">✕</a>
                </div>
            {% elseif table == 'characters' %}
                {% if filters.species %}
                    <div class="filter-item">
                        <label>Filtered by Species ID:</label>
                        <span class="filter-value">{{ filters.species }}</span>
                        <a href="{{ path('admin_table_view', {'table': 'characters'}) }}" class="clear-filter">✕</a>
                    </div>
                {% endif %}
                {% if filters.race %}
                    <div class="filter-item">
                        <label>Filtered by Race ID:</label>
                        <span class="filter-value">{{ filters.race }}</span>
                        <a href="{{ path('admin_table_view', {'table': 'characters'}) }}" class="clear-filter">✕</a>
                    </div>
                {% endif %}
            {% endif %}
        </form>
    </div>
    {% endif %}

    <!-- Table Stats -->
    <div class="table-stats">
        <div class="stat-item">
            <span class="stat-number">{{ total_count }}</span>
            <span class="stat-label">Total {{ config.title|replace({'Table': 'Records'}) }}</span>
        </div>
    </div>

    <!-- Data Table -->
    <div class="data-table-container">
        <table class="data-table">
            <thead>
                <tr>
                    {% for column in config.columns %}
                        <th>{{ column|replace({'_': ' '})|title }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for item in data %}
                <tr>
                    {% if table == 'species' %}
                        {% include 'admin/tables/rows/species_row.html.twig' with {'species': item} %}
                    {% elseif table == 'races' %}
                        {% include 'admin/tables/rows/race_row.html.twig' with {'race': item} %}
                    {% elseif table == 'characters' %}
                        {% include 'admin/tables/rows/character_row.html.twig' with {'character': item} %}
                    {% elseif table == 'users' %}
                        {% include 'admin/tables/rows/user_row.html.twig' with {'user': item} %}
                    {% endif %}
                </tr>
                {% else %}
                <tr>
                    <td colspan="{{ config.columns|length }}" class="empty-table">
                        <div class="empty-state">
                            <span class="empty-icon">{{ config.icon }}</span>
                            <p>No {{ table }} found in the database.</p>
                            {% if table == 'species' %}
                                <a href="{{ path('admin_species_new') }}" class="btn btn-primary">
                                    Create First Species
                                </a>
                            {% elseif table == 'races' %}
                                <a href="{{ path('admin_race_new') }}" class="btn btn-primary">
                                    Create First Race
                                </a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Related Content Section -->
    {% if table == 'species' and data|length > 0 %}
    <div class="related-content">
        <h3>Related Races & Characters</h3>
        <div class="related-grid">
            {% for species in data %}
                {% if species.races|length > 0 or species.characters|length > 0 %}
                <div class="related-species-card">
                    <h4>{{ species.name }} (ID: {{ species.id }})</h4>
                    
                    {% if species.races|length > 0 %}
                    <div class="related-section">
                        <h5>🎭 Races ({{ species.races|length }})</h5>
                        <div class="related-items">
                            {% for race in species.races %}
                            <a href="{{ path('admin_table_view', {'table': 'races'}) }}?species={{ species.id }}" 
                               class="related-item">
                                {{ race.name }} ({{ race.characters|length }} chars)
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}

                    {% if species.characters|length > 0 %}
                    <div class="related-section">
                        <h5>⚔️ Characters ({{ species.characters|length }})</h5>
                        <div class="related-items">
                            {% for character in species.characters %}
                            <a href="{{ path('admin_table_view', {'table': 'characters'}) }}?species={{ species.id }}" 
                               class="related-item">
                                {{ character.name }}
                                {% if character.race %} ({{ character.race.name }}){% endif %}
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {% if table == 'races' and data|length > 0 %}
    <div class="related-content">
        <h3>Related Characters</h3>
        <div class="related-grid">
            {% for race in data %}
                {% if race.characters|length > 0 %}
                <div class="related-race-card">
                    <h4>{{ race.name }} ({{ race.species.name }}) - ID: {{ race.id }}</h4>
                    
                    <div class="related-section">
                        <h5>⚔️ Characters ({{ race.characters|length }})</h5>
                        <div class="related-items">
                            {% for character in race.characters %}
                            <a href="{{ path('admin_table_detail', {'table': 'characters', 'id': character.id}) }}" 
                               class="related-item">
                                {{ character.name }}
                                {% if character.age %} ({{ character.age }} ans){% endif %}
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}