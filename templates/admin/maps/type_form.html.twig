{% extends 'base.html.twig' %}

{% block title %}{{ title }} - Administration{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/map.css') }}">
{% endblock %}

{% block body %}
<div class="admin-form-container">
    <div class="form-header">
        <a href="{{ path('admin_maps_index') }}" class="back-link">← Retour à la gestion</a>
        <h1>{{ title }}</h1>
    </div>
    
    {{ form_start(form, {'attr': {'class': 'admin-form'}}) }}
        <div class="form-group">
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
            {{ form_errors(form.name) }}
        </div>
        
        <div class="form-row">
            <div class="form-group half">
                {{ form_label(form.color) }}
                {{ form_widget(form.color) }}
                {{ form_errors(form.color) }}
                {% if type %}
                <div class="color-preview" style="background-color: {{ type.color }}; margin-top: 10px;"></div>
                {% endif %}
            </div>
            
            <div class="form-group half">
                {{ form_label(form.icon) }}
                {{ form_widget(form.icon) }}
                {{ form_errors(form.icon) }}
                {{ form_help(form.icon) }}
            </div>
        </div>
        
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                💾 {{ type ? 'Enregistrer les modifications' : 'Créer le type' }}
            </button>
            <a href="{{ path('admin_maps_index') }}" class="btn btn-secondary">
                ❌ Annuler
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
