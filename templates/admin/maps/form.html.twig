{% extends 'base.html.twig' %}

{% block title %}{{ title }} - Administration{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/map.css') }}">
{% endblock %}

{% block body %}
<div class="admin-form-container">
    <div class="form-header">
        <a href="{{ path('admin_maps_index') }}" class="back-link">← Retour à la gestion</a>
        <h1>{{ title }}</h1>
    </div>
    
    {{ form_start(form, {'attr': {'class': 'admin-form', 'enctype': 'multipart/form-data'}}) }}
        <div class="form-group">
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
            {{ form_errors(form.name) }}
        </div>
        
        <div class="form-group">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>
        
        <div class="form-group">
            {{ form_label(form.imageUpload) }}
            {% if map and map.imageFile %}
                <div class="current-image">
                    <p>Image actuelle :</p>
                    <img src="{{ asset('images/maps/' ~ map.imageFile) }}" alt="{{ map.name }}" class="preview-image">
                </div>
            {% endif %}
            {{ form_widget(form.imageUpload) }}
            {{ form_errors(form.imageUpload) }}
            {{ form_help(form.imageUpload) }}
        </div>
        
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                💾 {{ map ? 'Enregistrer les modifications' : 'Créer la carte' }}
            </button>
            <a href="{{ path('admin_maps_index') }}" class="btn btn-secondary">
                ❌ Annuler
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
