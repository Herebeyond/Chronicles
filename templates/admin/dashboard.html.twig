{% extends 'base.html.twig' %}

{% block title %}Administration - Chronicles{% endblock %}

{% block page_title %}Panneau d'Administration{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-shell">

    {# ===== Page header ===== #}
    <header class="admin-page-header">
        <div>
            <h1 class="admin-page-header__title">Tableau de bord</h1>
            <p class="admin-page-header__subtitle">
                Bienvenue {{ app.user.fullName ?? app.user.username }} —
                gérez votre univers en un seul endroit.
            </p>
        </div>
        <div class="admin-page-header__actions">
            <a href="{{ path('homepage') }}" class="btn-admin btn-admin--ghost">← Retour au site</a>
            <a href="{{ path('admin_users_index') }}" class="btn-admin btn-admin--primary">Gérer les utilisateurs</a>
        </div>
    </header>

    {# ===== KPI cards ===== #}
    <section class="admin-stats" aria-label="Statistiques">
        <article class="admin-stat admin-stat--species">
            <p class="admin-stat__label">Espèces</p>
            <p class="admin-stat__value">{{ stats.species_count }}</p>
            <p class="admin-stat__hint">Total des espèces enregistrées</p>
        </article>

        <article class="admin-stat admin-stat--races">
            <p class="admin-stat__label">Races</p>
            <p class="admin-stat__value">{{ stats.races_count }}</p>
            <p class="admin-stat__hint">Toutes espèces confondues</p>
        </article>

        <article class="admin-stat admin-stat--characters">
            <p class="admin-stat__label">Personnages</p>
            <p class="admin-stat__value">{{ stats.characters_count }}</p>
            <p class="admin-stat__hint">
                {{ stats.male_count }} ♂ · {{ stats.female_count }} ♀ · {{ stats.other_count }} autre(s)
            </p>
        </article>

        <article class="admin-stat admin-stat--users">
            <p class="admin-stat__label">Utilisateurs</p>
            <p class="admin-stat__value">{{ stats.users_count }}</p>
            <p class="admin-stat__hint">
                {{ stats.users_with_roles }} avec rôle · {{ stats.users_without_roles }} sans rôle
            </p>
        </article>
    </section>

    {# ===== Main grid: modules + sidebar ===== #}
    <div class="admin-grid">

        {# ----- Modules (main column) ----- #}
        <section aria-label="Modules d'administration">
            <div class="admin-modules">

                <article class="admin-module admin-module--species">
                    <header class="admin-module__head">
                        <span class="admin-module__icon" aria-hidden="true">🧬</span>
                        <h2 class="admin-module__title">Espèces &amp; Races</h2>
                    </header>
                    <p class="admin-module__desc">
                        Créez et organisez les espèces de votre univers et leurs races associées.
                    </p>
                    <div class="admin-module__actions">
                        <a href="{{ path('admin_species_management') }}" class="btn-admin btn-admin--primary">Gérer</a>
                        <a href="{{ path('admin_species_new') }}" class="btn-admin btn-admin--success">+ Espèce</a>
                        <a href="{{ path('admin_race_new') }}" class="btn-admin btn-admin--ghost">+ Race</a>
                    </div>
                </article>

                <article class="admin-module admin-module--characters">
                    <header class="admin-module__head">
                        <span class="admin-module__icon" aria-hidden="true">⚔️</span>
                        <h2 class="admin-module__title">Personnages</h2>
                    </header>
                    <p class="admin-module__desc">
                        Ajoutez des personnages à vos races, gérez leurs informations et historique.
                    </p>
                    <div class="admin-module__actions">
                        <a href="{{ path('admin_characters') }}" class="btn-admin btn-admin--primary">Gérer</a>
                        <a href="{{ path('characters_index') }}" class="btn-admin btn-admin--ghost">Voir la liste publique</a>
                    </div>
                </article>

                <article class="admin-module admin-module--users">
                    <header class="admin-module__head">
                        <span class="admin-module__icon" aria-hidden="true">👥</span>
                        <h2 class="admin-module__title">Utilisateurs</h2>
                    </header>
                    <p class="admin-module__desc">
                        Gérez les comptes, attribuez les rôles et suivez l'activité des membres.
                    </p>
                    <div class="admin-module__actions">
                        <a href="{{ path('admin_users_index') }}" class="btn-admin btn-admin--primary">Gérer</a>
                        <a href="{{ path('admin_users_create') }}" class="btn-admin btn-admin--success">+ Utilisateur</a>
                        <a href="{{ path('admin_users_stats') }}" class="btn-admin btn-admin--ghost">Statistiques</a>
                    </div>
                </article>

                <article class="admin-module admin-module--events">
                    <header class="admin-module__head">
                        <span class="admin-module__icon" aria-hidden="true">📅</span>
                        <h2 class="admin-module__title">Événements &amp; Calendrier</h2>
                    </header>
                    <p class="admin-module__desc">
                        Gérez la chronologie du monde et la configuration du calendrier custom.
                    </p>
                    <div class="admin-module__actions">
                        <a href="{{ path('admin_world_events_index') }}" class="btn-admin btn-admin--primary">Événements</a>
                        <a href="{{ path('admin_calendar_index') }}" class="btn-admin btn-admin--ghost">Calendrier</a>
                    </div>
                </article>

                <article class="admin-module admin-module--ideas">
                    <header class="admin-module__head">
                        <span class="admin-module__icon" aria-hidden="true">💡</span>
                        <h2 class="admin-module__title">Idées</h2>
                    </header>
                    <p class="admin-module__desc">
                        Consultez, organisez et exportez les idées de world-building.
                    </p>
                    <div class="admin-module__actions">
                        <a href="{{ path('ideas_index') }}" class="btn-admin btn-admin--primary">Voir</a>
                        <a href="{{ path('ideas_create') }}" class="btn-admin btn-admin--success">+ Idée</a>
                        <a href="{{ path('ideas_export') }}" class="btn-admin btn-admin--ghost">Exporter</a>
                    </div>
                </article>

                <article class="admin-module admin-module--data">
                    <header class="admin-module__head">
                        <span class="admin-module__icon" aria-hidden="true">📊</span>
                        <h2 class="admin-module__title">Tables de données</h2>
                    </header>
                    <p class="admin-module__desc">
                        Visualisez les tables brutes avec leurs liens relationnels.
                    </p>
                    <div class="admin-module__actions">
                        <a href="{{ path('admin_table_view', {'table': 'species'}) }}" class="btn-admin btn-admin--ghost">Espèces</a>
                        <a href="{{ path('admin_table_view', {'table': 'races'}) }}" class="btn-admin btn-admin--ghost">Races</a>
                        <a href="{{ path('admin_table_view', {'table': 'characters'}) }}" class="btn-admin btn-admin--ghost">Persos</a>
                        <a href="{{ path('admin_table_view', {'table': 'users'}) }}" class="btn-admin btn-admin--ghost">Users</a>
                    </div>
                </article>

            </div>
        </section>

        {# ----- Sidebar (right column) ----- #}
        <aside class="admin-sidebar" aria-label="Aperçus rapides">

            <section class="admin-section">
                <header class="admin-section__header">
                    <h3 class="admin-section__title">
                        <span class="admin-section__icon" aria-hidden="true">🆕</span>
                        Personnages récents
                    </h3>
                </header>
                {% if recent_characters is not empty %}
                    <ul class="admin-list">
                        {% for character in recent_characters %}
                            <li class="admin-list__item">
                                <a href="{{ path('characters_show', {'characterId': character.id}) }}">
                                    {{ character.name }}
                                </a>
                                <span class="admin-list__meta">
                                    {% if character.race %}{{ character.race.name }} · {% endif %}
                                    {{ character.createdAt|date('d/m/Y') }}
                                </span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="admin-list__empty">Aucun personnage pour le moment.</p>
                {% endif %}
            </section>

            <section class="admin-section">
                <header class="admin-section__header">
                    <h3 class="admin-section__title">
                        <span class="admin-section__icon" aria-hidden="true">🏆</span>
                        Espèces les plus riches
                    </h3>
                </header>
                {% if top_species is not empty %}
                    <ul class="admin-list">
                        {% for species in top_species %}
                            <li class="admin-list__item">
                                <a href="{{ path('beings_species', {'speciesId': species.id}) }}">
                                    {{ species.name }}
                                </a>
                                <span class="admin-list__meta">{{ species.races|length }} race(s)</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="admin-list__empty">Aucune espèce pour le moment.</p>
                {% endif %}
            </section>

            {% if user_role_stats is defined and user_role_stats is not empty %}
            <section class="admin-section">
                <header class="admin-section__header">
                    <h3 class="admin-section__title">
                        <span class="admin-section__icon" aria-hidden="true">🛡️</span>
                        Répartition des rôles
                    </h3>
                </header>
                <ul class="admin-list">
                    {% for role, count in user_role_stats %}
                        <li class="admin-list__item">
                            <span>{{ role|replace({'ROLE_': ''})|lower|title }}</span>
                            <span class="admin-list__meta">{{ count }} utilisateur(s)</span>
                        </li>
                    {% endfor %}
                </ul>
            </section>
            {% endif %}

        </aside>
    </div>

</div>
{% endblock %}
