{% extends 'base.html.twig' %}

{% block title %}Administration - Chronicles{% endblock %}

{% block page_title %}Panneau d'Administration{% endblock %}

{% block body %}
<div style="margin-bottom: 2rem;">
    <h2>Tableau de Bord Administrateur</h2>
    <p>Gérez votre univers fictif : espèces, races, personnages et plus encore.</p>
</div>

<!-- Quick Stats -->
<div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); margin-bottom: 3rem;">
    <div class="card" style="background: #3498db; color: white; text-align: center;">
        <h3 style="margin: 0 0 0.5rem 0;">Espèces</h3>
        <div style="font-size: 2.5rem; font-weight: bold;">0</div>
        <p style="margin: 0.5rem 0 0 0; opacity: 0.9;">Total des espèces</p>
    </div>
    
    <div class="card" style="background: #2ecc71; color: white; text-align: center;">
        <h3 style="margin: 0 0 0.5rem 0;">Races</h3>
        <div style="font-size: 2.5rem; font-weight: bold;">0</div>
        <p style="margin: 0.5rem 0 0 0; opacity: 0.9;">Total des races</p>
    </div>
    
    <div class="card" style="background: #e74c3c; color: white; text-align: center;">
        <h3 style="margin: 0 0 0.5rem 0;">Personnages</h3>
        <div style="font-size: 2.5rem; font-weight: bold;">0</div>
        <p style="margin: 0.5rem 0 0 0; opacity: 0.9;">Total des personnages</p>
    </div>
    
    <div class="card" style="background: #f39c12; color: white; text-align: center;">
        <h3 style="margin: 0 0 0.5rem 0;">Utilisateurs</h3>
        <div style="font-size: 2.5rem; font-weight: bold;">1</div>
        <p style="margin: 0.5rem 0 0 0; opacity: 0.9;">Utilisateurs actifs</p>
    </div>
</div>

<!-- Main Admin Actions -->
<div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));">
    
    <!-- Species & Race Management -->
    <div class="card">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">🧬</span>
            <div>
                <h3 style="margin: 0;">Gestion Espèces & Races</h3>
                <p style="margin: 0.5rem 0 0 0; color: #666;">Créer, modifier et organiser espèces et races</p>
            </div>
        </div>
        
        <div style="margin-bottom: 1rem;">
            <p>Gérez les espèces de votre univers et leurs races associées avec un interface intégrée.</p>
        </div>
        
        <div style="display: flex; gap: 0.5rem;">
            <a href="{{ path('admin_species_management') }}" class="btn" style="flex: 1;">Gérer Espèces & Races</a>
            <a href="{{ path('admin_species_new') }}" class="btn" style="background: #2ecc71;">+ Espèce</a>
            <a href="{{ path('admin_race_new') }}" class="btn" style="background: #3498db;">+ Race</a>
        </div>
    </div>

    <!-- Character Management -->
    <div class="card">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">👥</span>
            <div>
                <h3 style="margin: 0;">Gestion des Personnages</h3>
                <p style="margin: 0.5rem 0 0 0; color: #666;">Créer, modifier et supprimer des personnages</p>
            </div>
        </div>
        
        <div style="margin-bottom: 1rem;">
            <p>Ajoutez des personnages à vos races et espèces, gérez leurs informations et caractéristiques.</p>
        </div>
        
        <div style="display: flex; gap: 0.5rem;">
            <a href="{{ path('admin_characters') }}" class="btn" style="flex: 1;">Gérer les Personnages</a>
            <button onclick="quickAddCharacter()" class="btn" style="background: #2ecc71;">+ Nouveau</button>
        </div>
    </div>

    <!-- Database Management -->
    <div class="card">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">🗄️</span>
            <div>
                <h3 style="margin: 0;">Base de Données</h3>
                <p style="margin: 0.5rem 0 0 0; color: #666;">Opérations sur la base de données</p>
            </div>
        </div>
        
        <div style="margin-bottom: 1rem;">
            <p>Exportez, importez et gérez les données de votre univers fictif.</p>
        </div>
        
        <div style="display: flex; gap: 0.5rem;">
            <button onclick="exportData()" class="btn" style="background: #f39c12;">Exporter</button>
            <button onclick="importData()" class="btn" style="background: #9b59b6;">Importer</button>
        </div>
    </div>

    <!-- Database Tables View -->
    <div class="card">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">📊</span>
            <div>
                <h3 style="margin: 0;">Tables de Données</h3>
                <p style="margin: 0.5rem 0 0 0; color: #666;">Visualiser et naviguer dans les tables</p>
            </div>
        </div>
        
        <div style="margin-bottom: 1rem;">
            <p>Accédez aux vues détaillées de chaque table avec liens relationnels.</p>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
            <a href="{{ path('admin_table_view', {'table': 'species'}) }}" class="btn" style="background: #3498db;">📋 Species</a>
            <a href="{{ path('admin_table_view', {'table': 'races'}) }}" class="btn" style="background: #2ecc71;">📋 Races</a>
            <a href="{{ path('admin_table_view', {'table': 'characters'}) }}" class="btn" style="background: #e74c3c;">📋 Characters</a>
            <a href="{{ path('admin_table_view', {'table': 'users'}) }}" class="btn" style="background: #f39c12;">📋 Users</a>
        </div>
    </div>

    <!-- User Management -->
    <div class="card">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">👤</span>
            <div>
                <h3 style="margin: 0;">Gestion des Utilisateurs</h3>
                <p style="margin: 0.5rem 0 0 0; color: #666;">Gérer les comptes utilisateurs</p>
            </div>
        </div>
        
        <div style="margin-bottom: 1rem;">
            <p>Administrez les comptes utilisateurs, leurs permissions et leur accès.</p>
        </div>
        
        <div style="display: flex; gap: 0.5rem;">
            <button onclick="manageUsers()" class="btn" style="flex: 1;">Gérer les Utilisateurs</button>
        </div>
    </div>

    <!-- Dimensions Management -->
    <div class="card">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">🌍</span>
            <div>
                <h3 style="margin: 0;">Dimensions & Lieux</h3>
                <p style="margin: 0.5rem 0 0 0; color: #666;">Gérer les dimensions et les lieux</p>
            </div>
        </div>
        
        <div style="margin-bottom: 1rem;">
            <p>Créez et gérez les différentes dimensions, mondes et lieux de votre univers.</p>
        </div>
        
        <div style="display: flex; gap: 0.5rem;">
            <button onclick="manageDimensions()" class="btn" style="flex: 1;">Gérer les Dimensions</button>
        </div>
    </div>

    <!-- Ideas Management -->
    <div class="card">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">💡</span>
            <div>
                <h3 style="margin: 0;">Idées & Suggestions</h3>
                <p style="margin: 0.5rem 0 0 0; color: #666;">Gérer les idées d'amélioration</p>
            </div>
        </div>
        
        <div style="margin-bottom: 1rem;">
            <p>Consultez et gérez les idées et suggestions pour l'amélioration de l'univers.</p>
        </div>
        
        <div style="display: flex; gap: 0.5rem;">
            <button onclick="manageIdeas()" class="btn" style="flex: 1;">Gérer les Idées</button>
        </div>
    </div>

</div>

<!-- Recent Activity -->
<div style="margin-top: 3rem;">
    <div class="card">
        <h3>Activité Récente</h3>
        <div id="recent-activity">
            <div style="text-align: center; padding: 2rem; color: #666;">
                <span style="font-size: 3rem; opacity: 0.5;">📊</span>
                <p>Les logs d'activité seront affichés ici une fois le système complet</p>
            </div>
        </div>
    </div>
</div>

{% endblock %}

