{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} - {{ parent() }}{% endblock %}

{% block page_title %}{{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/hub-search.css') }}">
{% endblock %}

{% block body %}
<div class="hub-page"
     data-suggestions-endpoint="{{ path('hub_suggestions') }}"
    data-enabled-pages="{{ enabled_pages|join(',') }}"
    data-is-admin="{{ is_granted('ROLE_ADMIN') ? '1' : '0' }}"
    data-update-url-template="{{ path('admin_navigation_page_card_update', {'pageKey': '__PAGE_KEY__'}) }}">

    <div class="hub-hero">
        <h1>Navigation</h1>
        <p>Search names/titles first, then jump quickly to a page.</p>
    </div>

    <section class="hub-panel">
        <h2>Search Names / Titles</h2>
        <p class="hub-help">The search matches contiguous text (including -) and split tokens. Max: 10 suggestions.</p>
        <input id="hub-search-input"
               type="text"
               placeholder="Example: el, el da, dark-el"
               autocomplete="off"
               aria-label="Search items by name">

        <ul id="hub-suggestions" class="hub-suggestions" aria-live="polite"></ul>
    </section>

    <section class="hub-panel">
        <h2>Pages</h2>
        <p class="hub-help">Click a page card to open it directly.</p>
        <div class="hub-page-grid">
            {% for page in pages %}
                <div class="hub-page-card-item">
                    <a class="hub-page-card {% if page.cardImageUrl %}hub-page-card--with-image{% endif %}"
                       href="{{ path(page.routeName) }}"
                       style="{{ page.cardBackgroundStyle }}"
                       data-page-key="{{ page.key }}"
                       data-page-label="{{ page.label }}"
                       data-crop-x="{{ page.cardCrop.x }}"
                       data-crop-y="{{ page.cardCrop.y }}"
                       data-crop-size="{{ page.cardCrop.size }}">
                        <span class="hub-page-card__overlay"></span>
                        <span class="hub-page-card__title">{{ page.label }}</span>
                    </a>

                    {% if is_granted('ROLE_ADMIN') %}
                        <button class="hub-card-edit-btn"
                                type="button"
                                data-page-key="{{ page.key }}"
                                data-page-label="{{ page.label }}"
                                data-crop-x="{{ page.cardCrop.x }}"
                                data-crop-y="{{ page.cardCrop.y }}"
                                data-crop-size="{{ page.cardCrop.size }}"
                                data-csrf-token="{{ csrf_token('navigation_card_' ~ page.key) }}">
                            Edit image
                        </button>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </section>

    {% if is_granted('ROLE_ADMIN') %}
        <div class="hub-admin-modal" id="hub-admin-modal" hidden>
            <div class="hub-admin-modal__backdrop" data-close-modal="1"></div>
            <div class="hub-admin-modal__content" role="dialog" aria-modal="true" aria-labelledby="hub-admin-modal-title">
                <div class="hub-admin-modal__header">
                    <h3 id="hub-admin-modal-title">Edit page image</h3>
                    <button type="button" class="hub-admin-modal__close" data-close-modal="1">x</button>
                </div>

                <form id="hub-card-form" method="post" enctype="multipart/form-data" class="hub-card-form">
                    <input type="hidden" name="_token" id="hub-card-token">
                    <input type="hidden" name="crop_x" id="hub-crop-x" value="0">
                    <input type="hidden" name="crop_y" id="hub-crop-y" value="0">
                    <input type="hidden" name="crop_size" id="hub-crop-size" value="100">

                    <div class="hub-card-form__field">
                        <label for="hub-card-image-input">Upload image</label>
                        <input id="hub-card-image-input" name="image" type="file" accept="image/jpeg,image/png,image/webp,image/gif">
                    </div>

                    <div class="hub-card-editor">
                        <div class="hub-card-editor__preview" id="hub-card-preview-wrap">
                            <img id="hub-card-preview" alt="Image preview">
                            <div class="hub-card-crop-box" id="hub-card-crop-box"></div>
                        </div>
                    </div>

                    <div class="hub-card-form__field">
                        <label for="hub-crop-size-range">Square size</label>
                        <input id="hub-crop-size-range" type="range" min="10" max="100" step="1" value="100">
                    </div>

                    <div class="hub-card-form__actions">
                        <button type="button" class="hub-btn-secondary" data-close-modal="1">Cancel</button>
                        <button type="submit" class="hub-btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/hub-search.js') }}"></script>
{% endblock %}
