{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} - {{ parent() }}{% endblock %}

{% block page_title %}{{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/hub-search.css') }}">
{% endblock %}

{% block body %}
<div class="hub-page"
     data-suggestions-endpoint="{{ path('hub_suggestions') }}"
     data-enabled-pages="{{ enabled_pages|join(',') }}">

    <div class="hub-hero">
        <h1>Navigation</h1>
        <p>Search names/titles first, then jump quickly to a page.</p>
    </div>

    <section class="hub-panel">
        <h2>Search Names / Titles</h2>
        <p class="hub-help">The search matches contiguous text (including -) and split tokens. Max: 10 suggestions.</p>
        <input id="hub-search-input"
               type="text"
               placeholder="Example: el, el da, dark-el"
               autocomplete="off"
               aria-label="Search items by name">

        <ul id="hub-suggestions" class="hub-suggestions" aria-live="polite"></ul>
    </section>

    <section class="hub-panel">
        <h2>Pages</h2>
        <p class="hub-help">Click to open one of the available pages directly.</p>
        <div class="hub-page-chips">
            {% for page in pages %}
                <a class="hub-page-chip" href="{{ path(page.routeName) }}">{{ page.label }}</a>
            {% endfor %}
        </div>
    </section>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/hub-search.js') }}"></script>
{% endblock %}
